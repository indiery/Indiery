{
  "name": "indiery-phase1",
  "version": "1.0.0",
  "description": "Indiery - A delivery platform with customer, driver, and admin services",
  "private": true,
  "workspaces": [
    "apps/customer",
    "apps/driver",
    "backend",
    "apps/admin",
    "apps/shared"
  ],
  "scripts": {
    "install-all": "npm install",
    "start:customer": "cd apps/customer && npm start",
    "start:driver": "cd apps/driver && npm start",
    "start:backend": "cd backend && npm start",
    "build": "npm install && npm run build --workspaces",
    "test": "npm test --workspaces"
  },
  "keywords": [
    "delivery",
    "logistics",
    "ride-sharing"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "expo": "~49.0.0"
  }
}
