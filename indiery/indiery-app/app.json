{
  "expo": {
    "name": "indiery-app",
    "slug": "indiery-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "indieryapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "extra": {
      "EXPO_PUBLIC_FIREBASE_API_KEY": "AIzaSyDBCb63NtVtrctEN5sb1DP7a2h2AlEiHKs",
      "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "indiery-6a489.firebaseapp.com",
      "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "indiery-6a489",
      "EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET": "indiery-6a489.firebasestorage.app",
      "EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "1066705936060",
      "EXPO_PUBLIC_FIREBASE_APP_ID": "1:1066705936060:web:2d1eef2edde1f9b6f77ab9"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
