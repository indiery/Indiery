PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/indiery

# Redis
REDIS_URL=redis://localhost:6379

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT=./config/firebase-service-account.json

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# AWS S3 (for POD photos)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=indiery-pod-photos

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# FCM
FCM_SERVER_KEY=your-fcm-server-key

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Coins
COIN_REFUND_PERCENT=0.10
LATE_PENALTY_PERCENT=0.05
